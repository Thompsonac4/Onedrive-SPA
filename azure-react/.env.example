# Copy this file to ".env" and fill in your own values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Azure Entra App registration (SPA) client/application ID
VITE_MSAL_CLIENT_ID=your-app-client-id

# Login authority. Use "common" for multi-tenant, or your tenant ID.
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/common

# Microsoft Graph drive id that holds the jobsite folders
VITE_DRIVE_ID=your-drive-id

# Drive item id of the folder that contains the jobsite subfolders
VITE_JOBSITES_FOLDER_ID=your-jobsites-folder-id

# Optional friendly path (used as a fallback in some views)
VITE_JOBSITES_FOLDER_PATH=Projects
